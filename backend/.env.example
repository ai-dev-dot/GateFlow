DATABASE_URL=postgresql+asyncpg://db_user:db_password@localhost:5432/gateflow
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 上游 API Key 加密密钥（Fernet 格式，44 字节 base64）。生成命令：
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# 客户端 API Key 哈希密钥（至少 32 字节随机串）。生成命令：
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
HMAC_SECRET=replace-with-random-secret

# 审计日志数据策略。详见 README "数据存储与隐私" 章节。
# 是否持久化完整 LLM 请求/响应 body（加密）。true=存加密 body，false=只存短 preview（head...tail 格式）
AUDIT_LOG_FULL_BODY=false
# 审计日志保留天数（v0.2.0 实现自动清理）
AUDIT_LOG_RETENTION_DAYS=90
# 启用 PII 自动脱敏（v0.2.0 实现，当前不生效）
ENABLE_PII_REDACTION=false
